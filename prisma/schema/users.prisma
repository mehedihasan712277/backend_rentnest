model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String

  role         Role
  status       ActiveStatus @default(ACTIVE)

  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations

  profile         Profile?
  properties      Property[]
  rentalRequests  RentalRequest[]
  reviews         Review[]
  payments        Payment[]
  rentals Rental[]
}